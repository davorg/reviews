<!DOCTYPE html>
<html lang="en">
  <head>
[% IF site.ga4 -%]
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XK53RN4H4R"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '[% site.ga4 %]');
    </script>
[% END -%]

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Some book reviews from the ancient past.">
    <title>[% IF page.title; page.title; %] - [% END %] "Dave's Book Reviews" %]</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous">

    <style>
      :root {
        --page-bg: #f5f2ea;
        --panel-bg: #fffdf9;
        --sidebar-bg: #f0eadb;
        --border: #ddd4bf;
        --text: #2b2a28;
        --muted: #6c675f;
        --accent: #73510d;
        --accent-soft: #efe4c8;
      }

      body {
        background: var(--page-bg);
        color: var(--text);
      }

      a {
        color: #3e5fb8;
      }

      a:hover {
        color: #2f4d98;
      }

      .top-note {
        background: var(--accent-soft);
        border-bottom: 1px solid #d9c89a;
        color: #6f5315;
        font-size: 0.95rem;
      }

      .site-shell {
        min-height: 100vh;
      }

      .sidebar {
        background: var(--sidebar-bg);
        border-right: 1px solid var(--border);
      }

      .sidebar-inner {
        position: sticky;
        top: 1rem;
        max-height: calc(100vh - 2rem);
        overflow-y: auto;
      }

      .site-title {
        color: var(--accent);
        font-weight: 700;
        text-decoration: none;
      }

      .site-title:hover {
        color: #5d410a;
      }

      .review-nav .nav-link {
        color: #3d3a34;
        border-radius: 0.65rem;
        padding: 0.5rem 0.75rem;
        line-height: 1.35;
      }

      .review-nav .nav-link:hover {
        background: rgba(255,255,255,0.75);
      }

      .content-wrap {
        padding-top: 2rem;
        padding-bottom: 3rem;
      }

      .hero-card,
      .content-card {
        background: var(--panel-bg);
        border: 1px solid var(--border);
        border-radius: 1rem;
        box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.06);
      }

      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.78rem;
        color: var(--muted);
        font-weight: 700;
      }

      .hero-card h1 {
        font-size: clamp(2rem, 5vw, 3.25rem);
        line-height: 1.05;
        margin-bottom: 1rem;
      }

      .lede {
        font-size: 1.1rem;
        color: #4e4a43;
        max-width: 60ch;
      }

      .content-card .prose {
        max-width: 68ch;
      }

      .content-card p {
        font-size: 1.08rem;
        line-height: 1.8;
        margin-bottom: 1.3rem;
      }

      .section-rule {
        border-top: 1px solid var(--border);
      }

      footer {
        border-top: 1px solid var(--border);
        background: rgba(255,255,255,0.55);
        backdrop-filter: blur(6px);
      }

      @media (max-width: 991.98px) {
        .sidebar {
          border-right: 0;
          border-bottom: 1px solid var(--border);
        }

      .sidebar .site-title {
        font-size: 1.8rem;
        line-height: 1.1;
      }

      .sidebar-inner {
        position: static;
        max-height: none;
      }

      .content-wrap {
        padding-top: 1.25rem;
      }

      .review-nav .nav-link {
        font-size: 0.95rem;
        line-height: 1.35;
        padding-left: 0;
        padding-right: 0;
        border-radius: 0;
      }
    }

  .review-nav .nav-link:hover {
    text-decoration: underline;
    background: none;
  }

  .book-header {
    margin-bottom: 1rem;
  }

  .book-meta {
    background: #f7f3e8;
    border: 1px solid #ddd4bf;
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
  }

  .book-meta div + div {
    margin-top: 0.55rem;
  }

  .book-cover {
    max-width: 180px;
    height: auto;
  }

  .btn-amazon {
    background: #c97f1a;
    border-color: #b96f0a;
    color: white;
  }

  .btn-amazon:hover {
    background: #a96508;
    border-color: #9c5d05;
    color: white;
  }

  @media (max-width: 991.98px) {
    .buy {
      text-align: left !important;
    }

    .book-cover {
      max-width: 140px;
    }
  }

  .prose {
    max-width: 65ch;
  }

  .btn-outline-secondary {
    border-color: #bfae84;
    color: #5c4a1a;
  }

  .btn-outline-secondary:hover {
    background: #efe4c8;
    border-color: #bfae84;
    color: #5c4a1a;
  }

  @media (min-width: 992px) {
    #reviewsMenu {
      position: static;
      transform: none !important;
      visibility: visible !important;
      background: var(--sidebar-bg);
      border-right: 1px solid var(--border);
      width: auto;
    }

    #reviewsMenu .offcanvas-header {
      display: none;
    }

    #reviewsMenu .offcanvas-body {
      display: block;
      padding: 1rem 1.5rem;
      overflow-y: auto;
    }

    #reviewsMenu .sidebar-inner {
      position: sticky;
      top: 1rem;
      max-height: calc(100vh - 2rem);
      overflow-y: auto;
    }
  }

  .offcanvas {
    background: var(--sidebar-bg);
  }
    </style>
  </head>

  <body>
    <div class="top-note py-2">
      <div class="container text-center">
        The content on this page is very old (from 2001–2012) and is only left here for historical interest.
      </div>
    </div>

    <div class="d-lg-none bg-light border-bottom px-3 py-2">
      <button class="btn btn-outline-secondary" type="button"
              data-bs-toggle="offcanvas" data-bs-target="#reviewsMenu"
              aria-controls="reviewsMenu">
        ☰ Book reviews
      </button>
    </div>

    <div class="container-fluid site-shell">
      <div class="row">
        <div class="col-lg-3 col-xl-2">
          <aside class="sidebar px-0 offcanvas offcanvas-start offcanvas-lg"
                 tabindex="-1" id="reviewsMenu">

            <div class="offcanvas-header d-lg-none">
              <h5 class="offcanvas-title">Book reviews</h5>
              <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>

            <div class="sidebar-inner p-3 p-lg-4 offcanvas-body">
              <a href="/" class="site-title fs-2 d-inline-block mb-3">Book reviews</a>
              <p class="text-muted small mb-4">
                A preserved collection of Dave Cross's reviews of technical books from the early 2000s.
              </p>

              <nav aria-label="Book reviews navigation">
                <ul class="nav flex-column review-nav gap-1">
[% FOREACH book IN site.books; %]
                  <li class="nav-item"><a class="nav-link" href="/[% book.slug %]">[% book.title %]</a></li>
[% END %]
                </ul>
              </nav>
            </div>
          </aside>
        </div>

        <main class="col-12 col-lg-9 col-xl-10">
          <div class="content-wrap px-3 px-md-4 px-xl-5">
            <section class="hero-card p-4 p-md-5 mb-4">
              <div class="eyebrow mb-2">Archive</div>
              <h1>Dave's Book Reviews</h1>
              <p class="lede mb-0">
                Technical book reviews written between 2001 and 2012, preserved as a snapshot of an earlier web and an earlier era of computing books.
              </p>
            </section>

            <section class="content-card p-4 p-md-5">
[% content %]
            </section>
          </div>
        </main>
      </div>
    </div>

    <footer class="py-3">
      <div class="container text-center">
        <span class="text-muted">Made by <a href="https://links.davecross.co.uk/">Dave Cross</a> / Code on <a href="https://github.com/davorg/reviews/">GitHub</a></span>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"></script>
  </body>
</html>
